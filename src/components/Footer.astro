---
import { useTranslations } from '../i18n/utils';

interface Props {
  currentLang: 'en' | 'zh' | 'vi';
}

const { currentLang } = Astro.props;
const t = useTranslations(currentLang);
---

<footer class="bg-white dark:bg-gray-950 border-t border-gray-100 dark:border-gray-800/60 pt-24 pb-12 transition-colors duration-500">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Top Layer: Sitemap & Branding -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 mb-20">
      <!-- Branding Column -->
      <div class="md:col-span-5">
        <a href="#home" class="text-3xl font-black gradient-text inline-block mb-8">HJH</a>
        <p class="text-gray-500 dark:text-gray-400 text-lg leading-relaxed max-w-sm font-medium">
          {t('footer.about')}
        </p>
        <div class="mt-8 flex gap-4">
           <span class="inline-flex items-center px-3 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-[10px] font-black uppercase tracking-widest rounded-full border border-blue-100 dark:border-blue-800/30">
            {t('footer.available')}
          </span>
        </div>
      </div>

      <!-- Links Grid -->
      <div class="md:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-12">
        <div class="space-y-6">
          <h4 class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-[0.2em]">
            {t('nav.home')}
          </h4>
          <ul class="space-y-4">
            <li><a href="#home" class="text-sm font-bold text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{t('nav.home')}</a></li>
            <li><a href="#about" class="text-sm font-bold text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{t('nav.about')}</a></li>
            <li><a href="#projects" class="text-sm font-bold text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{t('nav.projects')}</a></li>
          </ul>
        </div>

        <div class="space-y-6">
          <h4 class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-[0.2em]">
            {t('footer.connect')}
          </h4>
          <ul class="space-y-4">
            <li>
              <a href="https://linkedin.com/in/jun-hong-ho-a82a57288" target="_blank" rel="noopener" class="text-sm font-bold text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                LinkedIn
              </a>
            </li>
            <li>
              <a href="https://github.com/LIONH456" target="_blank" rel="noopener" class="text-sm font-bold text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                GitHub
              </a>
            </li>
          </ul>
        </div>

        <div class="space-y-6 col-span-2 sm:col-span-1">
          <h4 class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-[0.2em]">
            {t('footer.location')}
          </h4>
          <p class="text-sm font-bold text-gray-600 dark:text-gray-400 leading-relaxed">
            Ho Chi Minh City,<br/>Vietnam
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Layer: Copyright & Info -->
    <div class="pt-10 border-t border-gray-100 dark:border-gray-800/60 flex flex-col sm:flex-row justify-between items-center gap-6">
      <div class="text-sm font-bold text-gray-400 dark:text-gray-500">
        © 2026 Ho Jun Hong.
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[11px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-[0.2em]">
          {t('footer.builtWith')}
        </span>
      </div>
    </div>
  </div>
</footer>
